
add-repos:
    helm repo add traefik https://traefik.github.io/charts
    helm repo add bitnami https://charts.bitnami.com/bitnami
    helm repo add gitea-charts https://dl.gitea.com/charts/
    helm repo add jetstack https://charts.jetstack.io
    helm repo add rustfs https://charts.rustfs.com/
    helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
    helm repo update


setup-dns:
    kubectl apply -f coredns-custom.yaml

# --- TLS (cert-manager + step-ca) ---

# Fetch step-ca root CA certificate for cert-manager trust
fetch-step-ca-root:
    curl -sk https://step-ca.lofi:9000/roots.pem -o cert-manager/step-ca-root.pem
    @echo "Saved step-ca root CA to cert-manager/step-ca-root.pem"

install-root-ca: fetch-step-ca-root
    sudo cp cert-manager/step-ca-root.pem /usr/local/share/ca-certificates/lofi-root-ca.crt
    sudo update-ca-certificates

# Deploy cert-manager with step-ca ACME ClusterIssuer
deploy-cert-manager:
    #!/usr/bin/env bash
    kubectl create namespace cert-manager --dry-run=client -o yaml | kubectl apply -f -
    helm upgrade --install cert-manager jetstack/cert-manager \
        --namespace cert-manager \
        --values cert-manager/values.yaml \
        --wait
    CA_BUNDLE=$(base64 -w0 cert-manager/step-ca-root.pem)
    sed "s|<CA_BUNDLE>|${CA_BUNDLE}|" cert-manager/cluster-issuer.yaml | kubectl apply -f -

# --- Deploy individual components ---

deploy-traefik:
    kubectl create namespace traefik --dry-run=client -o yaml | kubectl apply -f -
    helm upgrade --install traefik traefik/traefik \
        --namespace traefik \
        --values traefik/values.yaml \
        --wait
    kubectl apply -f traefik/gateway.yaml

deploy-postgres:
    kubectl create namespace postgres --dry-run=client -o yaml | kubectl apply -f -
    sops -d postgres/secrets.yaml | kubectl apply -f -
    helm upgrade --install postgres bitnami/postgresql \
        --namespace postgres \
        --values postgres/values.yaml \
        --wait
    kubectl apply -f postgres/pgadmin.yaml
    kubectl apply -f postgres/routes.yaml

deploy-gitea:
    kubectl create namespace gitea --dry-run=client -o yaml | kubectl apply -f -
    sops -d gitea/secrets.yaml | kubectl apply -f -
    helm upgrade --install gitea gitea-charts/gitea \
        --namespace gitea \
        --values gitea/values.yaml \
        --wait
    kubectl apply -f gitea/routes.yaml

deploy-rustfs:
    kubectl create namespace rustfs --dry-run=client -o yaml | kubectl apply -f -
    sops -d rustfs/secrets.yaml | kubectl apply -f -
    helm upgrade --install rustfs rustfs/rustfs \
        --namespace rustfs \
        --values rustfs/values.yaml \
        --wait
    kubectl apply -f rustfs/routes.yaml
    kubectl apply -f rustfs/bucket-job.yaml
    kubectl wait --for=condition=complete job/rustfs-bucket-init -n rustfs --timeout=120s

deploy-databasus:
    kubectl create namespace databasus --dry-run=client -o yaml | kubectl apply -f -
    sops -d databasus/secrets.yaml | kubectl apply -f -
    helm upgrade --install databasus \
        oci://ghcr.io/databasus/charts/databasus \
        --namespace databasus \
        --values databasus/values.yaml \
        --wait
    kubectl apply -f databasus/routes.yaml

build-databasus-operator:
    cd ~/oss/databasus/operator && make generate manifests
    cd ~/oss/databasus/operator && make docker-build IMG=databasus-operator:latest
    docker save databasus-operator:latest | sudo k3s ctr images import -

deploy-databasus-operator: build-databasus-operator
    cd ~/oss/databasus/operator && make install
    kubectl kustomize databasus/operator | kubectl apply -f -
    sops -d databasus/secrets.yaml | kubectl apply -f -
    kubectl apply -f databasus/operator/crs/storage-rustfs.yaml
    kubectl apply -f databasus/operator/crs/notifier-discord.yaml
    kubectl apply -f databasus/operator/crs/backup-gitea-rustfs.yaml

deploy-kube-state-metrics:
    kubectl create namespace kube-state-metrics --dry-run=client -o yaml | kubectl apply -f -
    helm upgrade --install kube-state-metrics prometheus-community/kube-state-metrics \
        --namespace kube-state-metrics \
        --values kube-state-metrics/values.yaml \
        --wait

deploy-gha-cache:
    kubectl create namespace gha-cache --dry-run=client -o yaml | kubectl apply -f -
    sops -d gha-cache/secrets.yaml | kubectl apply -f -
    helm upgrade --install gha-cache \
        oci://ghcr.io/falcondev-oss/charts/github-actions-cache-server \
        --namespace gha-cache \
        --values gha-cache/values.yaml \
        --wait

# Deploy Gitea actions runner (requires a registration token from Gitea admin panel)
deploy-runner token:
    kubectl create namespace gitea-actions --dry-run=client -o yaml | kubectl apply -f -
    sops -d gitea-actions/secrets.yaml | kubectl apply -f -
    kubectl create secret generic runner-token \
        --namespace gitea-actions \
        --from-literal=token={{ token }} \
        --dry-run=client -o yaml | kubectl apply -f -
    helm upgrade --install gitea-actions gitea-charts/actions \
        --namespace gitea-actions \
        --values gitea-actions/values.yaml \
        --wait

# Configure GitHub PAT for Gitea access to private repos
set-github-pat token:
    kubectl create secret generic github-pat \
        --namespace gitea \
        --from-literal=token={{ token }} \
        --dry-run=client -o yaml | kubectl apply -f -

# Deploy everything (except actions runner, which needs a token from Gitea)
deploy-all: add-repos setup-dns fetch-step-ca-root deploy-traefik deploy-cert-manager deploy-postgres deploy-rustfs deploy-gha-cache deploy-gitea deploy-databasus deploy-kube-state-metrics
    @echo ""
    @echo "All services deployed."
    @echo "Next steps:"
    @echo "  1. Add DNS entries for gitea.lofi and pgadmin.lofi -> any node IP"
    @echo "  2. Get a runner token from Gitea: Site Administration > Runners > Create new Runner"
    @echo "  3. Run: just deploy-runner <token>"

# --- Teardown ---

[confirm]
destroy-traefik:
    kubectl delete -f traefik/gateway.yaml --ignore-not-found
    helm uninstall traefik --namespace traefik --ignore-not-found
    kubectl delete namespace traefik --ignore-not-found
    kubectl get crd -o name | grep gateway.networking.k8s.io | xargs kubectl delete


[confirm]
destroy-postgres:
    kubectl delete -f postgres/routes.yaml --ignore-not-found
    kubectl delete -f postgres/pgadmin.yaml --ignore-not-found
    helm uninstall postgres --namespace postgres --ignore-not-found
    kubectl delete namespace postgres --ignore-not-found

[confirm]
destroy-gitea:
    kubectl delete -f gitea/routes.yaml --ignore-not-found
    kubectl delete -f gitea-actions/routes.yaml --ignore-not-found 2>/dev/null || true
    helm uninstall gitea-actions --namespace gitea-actions --ignore-not-found 2>/dev/null || true
    helm uninstall gitea --namespace gitea --ignore-not-found
    kubectl delete namespace gitea-actions --ignore-not-found 2>/dev/null || true
    kubectl delete namespace gitea --ignore-not-found

[confirm]
destroy-runner:
    kubectl delete -f gitea-actions/routes.yaml --ignore-not-found 2>/dev/null || true
    helm uninstall gitea-actions --namespace gitea-actions --ignore-not-found 2>/dev/null || true
    kubectl delete namespace gitea-actions --ignore-not-found 2>/dev/null || true

[confirm]
destroy-cert-manager:
    kubectl delete -f cert-manager/cluster-issuer.yaml --ignore-not-found
    helm uninstall cert-manager --namespace cert-manager --ignore-not-found
    kubectl delete namespace cert-manager --ignore-not-found

[confirm]
destroy-rustfs:
    kubectl delete -f rustfs/routes.yaml --ignore-not-found
    kubectl delete -f rustfs/bucket-job.yaml --ignore-not-found
    helm uninstall rustfs --namespace rustfs --ignore-not-found
    kubectl delete namespace rustfs --ignore-not-found

[confirm]
destroy-databasus-operator:
    kubectl delete -f databasus/databasebackup_gitea.yaml --ignore-not-found
    kubectl delete -f databasus/notifier_discord.yaml --ignore-not-found
    kubectl delete -f databasus/storage_s3.yaml --ignore-not-found
    kubectl kustomize databasus/operator | kubectl delete --ignore-not-found -f -
    cd ~/oss/databasus/operator && make uninstall

[confirm]
destroy-databasus:
    just destroy-databasus-operator 2>/dev/null || true
    kubectl delete -f databasus/routes.yaml --ignore-not-found
    helm uninstall databasus --namespace databasus --ignore-not-found
    kubectl delete namespace databasus --ignore-not-found

[confirm]
destroy-kube-state-metrics:
    helm uninstall kube-state-metrics --namespace kube-state-metrics --ignore-not-found
    kubectl delete namespace kube-state-metrics --ignore-not-found

[confirm]
destroy-gha-cache:
    helm uninstall gha-cache --namespace gha-cache --ignore-not-found
    kubectl delete namespace gha-cache --ignore-not-found

[confirm]
destroy-all: destroy-databasus destroy-gha-cache destroy-kube-state-metrics destroy-rustfs destroy-gitea destroy-postgres destroy-cert-manager destroy-traefik

